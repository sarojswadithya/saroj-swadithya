# Copy this file to .env.local and fill in your real values.
# .env.local is gitignored and will NOT be committed to GitHub.

# WhatsApp number in FULL INTERNATIONAL format, digits only (no + or spaces).
# Country code first. Example for India: 919999999999
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Email shown across the site
NEXT_PUBLIC_CONTACT_EMAIL=

# Optional pre-filled WhatsApp message
NEXT_PUBLIC_WHATSAPP_MESSAGE=
