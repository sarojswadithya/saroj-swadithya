# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — keep secrets out of the repo.
# .env.example is the template (committed); everything else is local only.
.env*
!.env.example

# project banner screenshots — kept local to keep the repo lean.
# The site uses the SVG versions (smaller, committed).
public/banners/*.png

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
